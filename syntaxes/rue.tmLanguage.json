{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Rue",
	"scopeName": "source.rue",
	"fileTypes": [
		"rue"
	],
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#func-block"
		},
		{
			"include": "#def-variable"
		},
		{
			"include": "#at-rules"
		},
		{
			"include": "#rule-block"
		},
		{
			"include": "#property"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.block.rue",
					"begin": "/\\*",
					"end": "\\*/",
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.rue"
						}
					}
				},
				{
					"name": "comment.line.double-slash.rue",
					"match": "//.*$"
				}
			]
		},
		"func-block": {
			"name": "meta.function.declaration.rue",
			"begin": "(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\([^)]*\\))\\s*(\\{)",
			"beginCaptures": {
				"1": {
					"name": "keyword.declaration.function.rue"
				},
				"2": {
					"name": "entity.name.function.rue"
				},
				"3": {
					"name": "punctuation.definition.parameters.rue"
				},
				"4": {
					"name": "punctuation.section.block.begin.rue"
				}
			},
			"end": "^\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.section.block.end.rue"
				}
			},
			"contentName": "meta.embedded.block.javascript",
			"patterns": [
				{
					"include": "source.js"
				}
			]
		},
		"def-variable": {
			"name": "meta.def.rue",
			"match": "\\b(def)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(:)\\s*(.+?)\\s*$",
			"captures": {
				"1": {
					"name": "keyword.control.def.rue"
				},
				"2": {
					"name": "variable.declaration.rue"
				},
				"3": {
					"name": "punctuation.separator.rue"
				},
				"4": {
					"name": "meta.def.value.rue",
					"patterns": [
						{
							"include": "#value-contents"
						}
					]
				}
			}
		},
		"at-rules": {
			"patterns": [
				{
					"name": "meta.at-rule.rue",
					"begin": "(@[a-zA-Z-]+)\\s*([^{;]*)?\\s*(\\{)",
					"beginCaptures": {
						"1": {
							"name": "keyword.control.at-rule.rue"
						},
						"2": {
							"name": "string.unquoted.at-rule-params.rue"
						},
						"3": {
							"name": "punctuation.section.block.begin.rue"
						}
					},
					"end": "\\}",
					"endCaptures": {
						"0": {
							"name": "punctuation.section.block.end.rue"
						}
					},
					"patterns": [
						{
							"include": "#comments"
						},
						{
							"include": "#rule-block"
						},
						{
							"include": "#property"
						}
					]
				},
				{
					"name": "meta.at-rule.simple.rue",
					"match": "(@[a-zA-Z-]+)\\s*([^;]+)?\\s*(;)",
					"captures": {
						"1": {
							"name": "keyword.control.at-rule.rue"
						},
						"2": {
							"name": "string.unquoted.at-rule-params.rue"
						},
						"3": {
							"name": "punctuation.terminator.rue"
						}
					}
				}
			]
		},
		"rule-block": {
			"name": "meta.rule-block.rue",
			"begin": "(?!\\s*func\\b)([^{};/\"']+?)\\s*(\\{)",
			"beginCaptures": {
				"1": {
					"name": "meta.selector.rue",
					"patterns": [
						{
							"include": "#selector"
						}
					]
				},
				"2": {
					"name": "punctuation.section.block.begin.rue"
				}
			},
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.section.block.end.rue"
				}
			},
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"include": "#rule-block"
				},
				{
					"include": "#property"
				}
			]
		},
		"selector": {
			"patterns": [
				{
					"name": "entity.name.tag.rue",
					"match": "\\b(a|abbr|address|article|aside|audio|b|blockquote|body|br|button|canvas|caption|cite|code|col|colgroup|data|datalist|dd|del|details|dfn|dialog|div|dl|dt|em|embed|fieldset|figcaption|figure|footer|form|h1|h2|h3|h4|h5|h6|head|header|hr|html|i|iframe|img|input|ins|kbd|label|legend|li|link|main|map|mark|menu|meta|meter|nav|noscript|object|ol|optgroup|option|output|p|picture|pre|progress|q|rp|rt|ruby|s|samp|script|section|select|small|source|span|strong|style|sub|summary|sup|table|tbody|td|template|textarea|tfoot|th|thead|time|title|tr|track|u|ul|var|video|wbr)\\b"
				},
				{
					"name": "entity.other.attribute-name.class.rue",
					"match": "\\.[a-zA-Z_][a-zA-Z0-9_-]*"
				},
				{
					"name": "entity.other.attribute-name.id.rue",
					"match": "#[a-zA-Z_][a-zA-Z0-9_-]*"
				},
				{
					"name": "entity.other.attribute-name.pseudo-class.rue",
					"match": ":{1,2}[a-zA-Z_][a-zA-Z0-9_-]*"
				},
				{
					"name": "entity.other.attribute-name.attribute.rue",
					"match": "\\[[^\\]]*\\]"
				},
				{
					"name": "keyword.operator.combinator.rue",
					"match": "[>~+|]"
				},
				{
					"name": "keyword.operator.wildcard.rue",
					"match": "\\*"
				},
				{
					"name": "punctuation.separator.selector.rue",
					"match": ","
				}
			]
		},
		"property": {
			"name": "meta.property.rue",
			"begin": "\\s*([a-zA-Z-]+)\\s*(:)\\s*",
			"beginCaptures": {
				"1": {
					"name": "support.type.property-name.rue"
				},
				"2": {
					"name": "punctuation.separator.key-value.rue"
				}
			},
			"end": "\\s*(;)|(?=\\})",
			"endCaptures": {
				"1": {
					"name": "punctuation.terminator.rue"
				}
			},
			"patterns": [
				{
					"include": "#value-contents"
				}
			]
		},
		"value-contents": {
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"include": "#variable-call"
				},
				{
					"include": "#calc-expression"
				},
				{
					"include": "#css-variable"
				},
				{
					"include": "#important"
				},
				{
					"include": "#string"
				},
				{
					"include": "#color-hex"
				},
				{
					"include": "#color-function"
				},
				{
					"include": "#css-function"
				},
				{
					"include": "#numeric-value"
				},
				{
					"include": "#named-value"
				}
			]
		},
		"variable-call": {
			"name": "variable.other.rue",
			"match": "_[a-zA-Z_][a-zA-Z0-9_-]*"
		},
		"calc-expression": {
			"name": "meta.calc.rue",
			"begin": "\\{",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.calc.begin.rue"
				}
			},
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.calc.end.rue"
				}
			},
			"patterns": [
				{
					"include": "#variable-call"
				},
				{
					"include": "#css-variable"
				},
				{
					"include": "#numeric-value"
				},
				{
					"name": "keyword.operator.arithmetic.rue",
					"match": "[+\\-*/]"
				}
			]
		},
		"css-variable": {
			"name": "variable.other.custom-property.rue",
			"match": "--[a-zA-Z_][a-zA-Z0-9_-]*"
		},
		"important": {
			"name": "keyword.other.important.rue",
			"match": "!important"
		},
		"string": {
			"patterns": [
				{
					"name": "string.quoted.double.rue",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.rue",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.rue",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.rue",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"color-hex": {
			"name": "constant.other.color.rgb-value.rue",
			"match": "#([0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})\\b"
		},
		"color-function": {
			"name": "meta.function.color.rue",
			"begin": "\\b(rgb|rgba|hsl|hsla|hwb|lab|lch|oklch|oklab|color)\\s*(\\()",
			"beginCaptures": {
				"1": {
					"name": "support.function.color.rue"
				},
				"2": {
					"name": "punctuation.section.function.begin.rue"
				}
			},
			"end": "\\)",
			"endCaptures": {
				"0": {
					"name": "punctuation.section.function.end.rue"
				}
			},
			"patterns": [
				{
					"include": "#numeric-value"
				},
				{
					"name": "punctuation.separator.rue",
					"match": ","
				}
			]
		},
		"css-function": {
			"name": "meta.function.rue",
			"begin": "\\b(var|env|attr|url|format|local|linear-gradient|radial-gradient|conic-gradient|repeating-linear-gradient|repeating-radial-gradient|image|image-set|cross-fade|element|counter|counters|symbols|cubic-bezier|steps|translate|translateX|translateY|translateZ|translate3d|scale|scaleX|scaleY|rotate|rotateX|rotateY|rotateZ|rotate3d|skew|skewX|skewY|matrix|matrix3d|perspective|blur|brightness|contrast|drop-shadow|grayscale|hue-rotate|invert|opacity|saturate|sepia|minmax|fit-content|repeat|clamp|min|max)\\s*(\\()",
			"beginCaptures": {
				"1": {
					"name": "support.function.rue"
				},
				"2": {
					"name": "punctuation.section.function.begin.rue"
				}
			},
			"end": "\\)",
			"endCaptures": {
				"0": {
					"name": "punctuation.section.function.end.rue"
				}
			},
			"patterns": [
				{
					"include": "#variable-call"
				},
				{
					"include": "#css-variable"
				},
				{
					"include": "#numeric-value"
				},
				{
					"include": "#string"
				},
				{
					"include": "#color-hex"
				},
				{
					"name": "punctuation.separator.rue",
					"match": ","
				}
			]
		},
		"numeric-value": {
			"patterns": [
				{
					"name": "constant.numeric.rue",
					"match": "-?\\d*\\.?\\d+(px|em|rem|vh|vw|vmin|vmax|svh|svw|dvh|dvw|lvh|lvw|%|pt|pc|cm|mm|in|ex|ch|fr|deg|rad|turn|grad|ms|s|dpi|dpcm|dppx)\\b"
				},
				{
					"name": "constant.numeric.unitless.rue",
					"match": "-?\\d*\\.?\\d+"
				}
			]
		},
		"named-value": {
			"patterns": [
				{
					"name": "support.constant.property-value.rue",
					"match": "\\b(none|auto|inherit|initial|unset|revert|revert-layer|normal|bold|italic|underline|solid|dashed|dotted|double|groove|ridge|inset|outset|hidden|visible|hidden|scroll|clip|flex|grid|block|inline|inline-block|inline-flex|inline-grid|contents|flow-root|table|list-item|absolute|relative|fixed|sticky|static|left|right|center|top|bottom|middle|baseline|stretch|start|end|flex-start|flex-end|space-between|space-around|space-evenly|wrap|nowrap|wrap-reverse|row|column|row-reverse|column-reverse|pointer|default|text|move|not-allowed|grab|grabbing|zoom-in|zoom-out|crosshair|help|wait|progress|all-scroll|col-resize|row-resize|n-resize|e-resize|s-resize|w-resize|ne-resize|nw-resize|se-resize|sw-resize|ew-resize|ns-resize|nesw-resize|nwse-resize|serif|sans-serif|monospace|cursive|fantasy|system-ui|contain|cover|no-repeat|repeat|repeat-x|repeat-y|round|space|border-box|content-box|padding-box|transparent|currentColor|currentcolor|ltr|rtl|uppercase|lowercase|capitalize|break-word|break-all|keep-all|pre|pre-wrap|pre-line|collapse|separate|both|forwards|backwards|infinite|alternate|alternate-reverse|running|paused|ease|ease-in|ease-out|ease-in-out|linear|step-start|step-end|fill|stroke|evenodd|nonzero|flat|preserve-3d|balance|auto-fill|auto-fit|subgrid|dense|max-content|min-content|fit-content)\\b"
				},
				{
					"name": "support.constant.color.w3c-standard-color-name.rue",
					"match": "\\b(aliceblue|antiquewhite|aqua|aquamarine|azure|beige|bisque|black|blanchedalmond|blue|blueviolet|brown|burlywood|cadetblue|chartreuse|chocolate|coral|cornflowerblue|cornsilk|crimson|cyan|darkblue|darkcyan|darkgoldenrod|darkgray|darkgreen|darkgrey|darkkhaki|darkmagenta|darkolivegreen|darkorange|darkorchid|darkred|darksalmon|darkseagreen|darkslateblue|darkslategray|darkslategrey|darkturquoise|darkviolet|deeppink|deepskyblue|dimgray|dimgrey|dodgerblue|firebrick|floralwhite|forestgreen|fuchsia|gainsboro|ghostwhite|gold|goldenrod|gray|green|greenyellow|grey|honeydew|hotpink|indianred|indigo|ivory|khaki|lavender|lavenderblush|lawngreen|lemonchiffon|lightblue|lightcoral|lightcyan|lightgoldenrodyellow|lightgray|lightgreen|lightgrey|lightpink|lightsalmon|lightseagreen|lightskyblue|lightslategray|lightslategrey|lightsteelblue|lightyellow|lime|limegreen|linen|magenta|maroon|mediumaquamarine|mediumblue|mediumorchid|mediumpurple|mediumseagreen|mediumslateblue|mediumspringgreen|mediumturquoise|mediumvioletred|midnightblue|mintcream|mistyrose|moccasin|navajowhite|navy|oldlace|olive|olivedrab|orange|orangered|orchid|palegoldenrod|palegreen|paleturquoise|palevioletred|papayawhip|peachpuff|peru|pink|plum|powderblue|purple|rebeccapurple|red|rosybrown|royalblue|saddlebrown|salmon|sandybrown|seagreen|seashell|sienna|silver|skyblue|slateblue|slategray|slategrey|snow|springgreen|steelblue|tan|teal|thistle|tomato|turquoise|violet|wheat|white|whitesmoke|yellow|yellowgreen)\\b"
				}
			]
		}
	}
}