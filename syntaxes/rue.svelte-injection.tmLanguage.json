{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Rue Svelte Injection",
    "scopeName": "source.rue.svelte",
    "injectionSelector": "L:meta.lang.rue.svelte - (meta source)",
    "patterns": [
        { "include": "#func-block" },
        { "include": "source.rue" }
    ],
    "repository": {
        "func-block": {
            "name": "meta.function.declaration.rue",
            "begin": "(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\([^)]*\\))\\s*(\\{)",
            "beginCaptures": {
                "1": { "name": "keyword.declaration.function.rue" },
                "2": { "name": "entity.name.function.rue" },
                "3": { "name": "punctuation.definition.parameters.rue" },
                "4": { "name": "punctuation.section.block.begin.rue" }
            },
            "end": "^\\}",
            "endCaptures": {
                "0": { "name": "punctuation.section.block.end.rue" }
            },
            "contentName": "meta.embedded.block.javascript",
            "patterns": [
                { "include": "source.js" }
            ]
        }
    }
}